{
  "_comment": "Full Render HQ — Highest quality extraction. Use for final content review.",
  "name": "Full Render HQ",
  "description": "5fps, near-lossless JPEG, strict blur/dedup, top-30 scored frames.",

  "extraction": {
    "mode": "fps",
    "fps": 5,
    "jpeg_quality": 2
  },

  "filter": {
    "blur_threshold": 100.0,
    "similarity_threshold": 0.65,
    "dedup_method": "phash",
    "phash_size": 16
  },

  "scorer": {
    "enabled": true,
    "top_n": 30,
    "save_score_report": true
  },

  "output": {
    "naming_pattern": "{video_name}",
    "generate_html_preview": true,
    "preview_columns": 5,
    "report_json": true,
    "keep_raw": false
  }
}
